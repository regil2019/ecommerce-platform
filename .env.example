# =============================================================================
# E-COMMERCE APPLICATION ENVIRONMENT VARIABLES
# =============================================================================

# Application Environment
NODE_ENV=development
VITE_APP_ENV=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=ecommerce_user
DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_ROOT_PASSWORD

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# =============================================================================
# APPLICATION PORTS
# =============================================================================
BACKEND_PORT=4000
FRONTEND_PORT=3000

# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================
# Initial admin account (used by scripts/create-admin.js)
ADMIN_EMAIL=REPLACE_WITH_YOUR_ADMIN_EMAIL
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
ADMIN_NAME=Admin
# Comma-separated list of emails that get admin role on register
ADMIN_EMAILS=REPLACE_WITH_YOUR_ADMIN_EMAIL

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# CLOUDINARY CONFIGURATION (Image Storage)
# =============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================================================================
# STRIPE CONFIGURATION (Payment Processing)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# EMAIL CONFIGURATION (Notifications)
# =============================================================================
# SMTP Configuration (legacy)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_EMAIL
SMTP_PASS=REPLACE_WITH_SMTP_APP_PASSWORD
FROM_EMAIL=REPLACE_WITH_FROM_EMAIL
FROM_NAME=REPLACE_WITH_STORE_NAME

# EmailJS Configuration
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_ORDER_CONFIRMATION_TEMPLATE=your_order_confirmation_template_id
EMAILJS_WELCOME_TEMPLATE=your_welcome_template_id
EMAILJS_ORDER_STATUS_UPDATE_TEMPLATE=your_order_status_update_template_id
EMAILJS_PASSWORD_RESET_TEMPLATE=your_password_reset_template_id

# =============================================================================
# FRONTEND API URL
# =============================================================================
VITE_API_URL=http://localhost:4000/api
FRONTEND_URL=http://localhost:3000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
MAX_FILE_SIZE=5000000
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
SENTRY_DSN=your_sentry_dsn_here
GOOGLE_ANALYTICS_ID=your_ga_id_here

# =============================================================================
# DEVELOPMENT SPECIFIC
# =============================================================================
DEBUG=ecommerce:*
ENABLE_SWAGGER=true

# =============================================================================
# AI CONFIGURATION
# =============================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key

# =============================================================================
# PRODUCTION SPECIFIC
# =============================================================================
# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/your_domain.crt
SSL_KEY_PATH=/etc/ssl/private/your_domain.key

# CDN Configuration
CDN_URL=https://your-cdn-domain.com

# =============================================================================
# DOCKER SPECIFIC
# =============================================================================
# For docker-compose overrides
COMPOSE_PROJECT_NAME=ecommerce

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
